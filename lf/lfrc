source lfrc-common

set shellflag '-c'
set previewer preview

# open with bat
cmd open ${{ bat --paging=always "$f" }}

# open in VS Code
map o $code --goto "$f"

# yank path to clipboard
cmd yank-path ${{
    case "$(uname -s)" in
        Linux) printf '%s' "$f" | clip.exe 2>/dev/null || printf '%s' "$f" | xclip -selection clipboard ;;
        *)     printf '%s' "$f" | clip ;;
    esac
}}
map Y yank-path

# zoxide jump
cmd zoxide-jump ${{
    dir=$(zoxide query -i)
    [ -n "$dir" ] && lf -remote "send $id cd \"$dir\""
}}
map z zoxide-jump
